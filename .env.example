# Copy to .env and adjust for your LAN deployment.

POSTGRES_USER=speedtest
POSTGRES_PASSWORD=speedtest
POSTGRES_DB=speedtest
POSTGRES_PORT=5432

# Used by the API container (override if you change postgres credentials).
DATABASE_URL=postgresql+psycopg://speedtest:speedtest@postgres:5432/speedtest

# Comma-separated browser origins allowed to call the API directly (dev + docker UI).
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173

# Logical label stored on each saved run unless the client overrides it.
SERVER_LABEL=default

FRONTEND_PORT=8081
LOG_LEVEL=INFO

# Expose Prometheus metrics from the API (`/metrics`).
ENABLE_METRICS=true

# Optional: bearer for POST /api/admin/prune (omit to disable token check if your deployment allows).
# ADMIN_PRUNE_TOKEN=
